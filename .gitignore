# This .gitignore file should be placed at the root of your Unity project directory
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Build]
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory dumps
*.lldb

# OS generated files
.DS_Store
Thumbs.db

# Unity WebGL Build folders
[Aa]ssets/[Ss]treamingAssets/Build
[Aa]ssets/[Ss]treamingAssets/build.meta

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity3D generated meta files
/*.pidb.meta
/*.syncproj.meta

# Unity3D Generated File Groups
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]sset[Ss]ettings/[Ll]ink[Pp]resentation[Aa]ssets/
/[Aa]ssets/[Pp]lay[Mm]ode[Ss]aved[Ss]tate/

# Temporary files created by Unity Editor
~*
